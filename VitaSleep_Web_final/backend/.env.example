# VitaSleep Web Final - Backend 环境变量配置

# ==========================================
# 数据库配置
# ==========================================
DATABASE_URL=sqlite+aiosqlite:///./app/vitasleep.db

# ==========================================
# 服务配置
# ==========================================
BACKEND_PORT=8000
LOG_LEVEL=INFO

# ==========================================
# CORS 配置
# ==========================================
CORS_ORIGINS=http://localhost,http://localhost:3000

# ==========================================
# Agent 服务配置（V2.0 新增）
# ==========================================
# Agent 服务地址
AGENT_SERVICE_URL=http://localhost:8001

# 是否启用 Agent 服务（true/false）
# 设置为 false 时将直接调用 LLM（降级模式）
USE_AGENT_SERVICE=true

# ==========================================
# LLM 配置（降级使用）
# ==========================================
# 智谱 AI 配置
LLM_BASE_URL=https://open.bigmodel.cn/api/coding/paas/v4
LLM_API_KEY=your_zhipu_api_key_here
LLM_MODEL=glm-5.1

# LLM 生成参数
LLM_MAX_TOKENS=1024
LLM_TEMPERATURE=0.7

# ==========================================
# Veepoo 设备模式
# ==========================================
# 设为 true 时禁用模拟器，接收真实设备数据
USE_VEEPOO_DATA=true
